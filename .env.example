# Local environment example for Vercel deployment
# Copy this to .env when running locally with a tool like dotenv.

FIREBASE_PROJECT_ID=minasshow-box
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@minasshow-box.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Optional: override Make.com account from public/make-accounts.json at build time (home page).
# Values must match a key under "accounts" in make-accounts.json, e.g. louismarco226 | marcolous11
# VITE_MAKE_ACCOUNT=marcolous11
